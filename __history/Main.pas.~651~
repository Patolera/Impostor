procedure TfrmImpostor.recBotaoClick(Sender: TObject);
var
  i: integer;
  Edit: TEdit;
  preenchidos: Boolean;
begin
  circleImpostor.Visible := False;
  StopHeartbeat(imgLogo);

  if tab.ActiveTab = tbNomes then
  begin
    for i := 0 to Edits.Count - 1 do
    begin
      Edit := Edits[i];
      Jogadores[i].ID := i + 1;
      if Edit.Text.Trim > '' then
        Jogadores[i].Nome := Edit.Text.Trim
      else
        Jogadores[i].Nome := Edit.TextPrompt;
    end;
    ZeraPontos;
    Randomiza;
    ComecaJogo;
    tab.ActiveTab := tbJogo;
  end
  else if tab.ActiveTab = tbMain then
  begin
    CheckSwitchsTemas;
    tab.ActiveTab := tbNomes;
  end
  else if tab.ActiveTab = tbRegras then
  begin
    if recPontos.Tag = 1 then
      tab.ActiveTab := tbPontos
    else
      ResetGame;
  end
  else if tab.ActiveTab = tbVerCondicao then
  begin
    tab.ActiveTab := tbJogo;
  end
  else if tab.ActiveTab = tbJogo then
  begin
    ShowModalConfirm('Voltar para o início?',
      procedure(Result: Boolean)
      begin
        if not Result then tab.ActiveTab := tbMain;
      end);
  end
  else if tab.ActiveTab = tbPontos then
  begin
    ResetGame;
  end
  else if tab.ActiveTab = tbVencedor then
  begin
    TemaEscolhido := '';
    JogadorInicial:= '';
    SetLength(Jogadores, 0);
    tab.ActiveTab := tbMain;
  end;
end;

