procedure TfrmImpostor.ResetGame;
var
  Resposta: Integer;
begin
  Randomiza;
  ComecaJogo;
  tab.ActiveTab := tbJogo;
  Exit;
  ShowModalConfirm('Jogar com as mesmas regras?',
  procedure(Result: Boolean)
  begin
    if not Result then
    begin
      Randomiza;
      ComecaJogo;
      tab.ActiveTab := tbJogo;
    end
    else
    begin
      TemaEscolhido := '';
      JogadorInicial:= '';

      SetLength(Jogadores, 0);

      if Assigned(Edits) then
      begin
        for var Edit in Edits do
          Edit.DisposeOf;
        Edits.Clear;
      end;

      if Assigned(Flows) then
      begin
        for var Flow in Flows do
          Flow.DisposeOf;
        Flows.Clear;
      end;

      tab.ActiveTab := tbMain;
    end;
  end);

end;


