function TfrmImpostor.GetIniFileName: string;
begin
  Result := TPath.Combine(TPath.GetDocumentsPath, 'config.ini');
end;

procedure TfrmImpostor.SalvarStatus;
var
  Ini: TMemIniFile;
begin
  Ini := TMemIniFile.Create(GetIniFileName);
  try
    Ini.WriteBool('Config', 'NaoMostrarInstr', chkNaoMostrarInstr.IsChecked);
    Ini.UpdateFile;
  finally
    Ini.Free;
  end;
end;


procedure TfrmImpostor.LerStatus;
var
  Ini: TMemIniFile;
begin
  if not TFile.Exists(GetIniFileName) then
    Exit;

  Ini := TMemIniFile.Create(GetIniFileName);
  try
    chkNaoMostrarInstr.IsChecked := Ini.ReadBool('Config', 'NaoMostrarInstr', False);
  finally
    Ini.Free;
  end;
end;

procedure TfrmImpostor.Randomiza;
var
  TemasAtivos: TArray<string>;
  i, idx, count: Integer;
  Indices: TList<Integer>;
  msg:string;
  PalavraEscolhida: TPalavra;
  Temp: TArray<TPalavra>;
  PalavrasFiltradas: TArray<TPalavra>;
begin
  TemasAtivos := [];

  if recTemasFilmes.Tag = 1 then
    TemasAtivos := TemasAtivos + ['Filmes'];
  if recTemasMarcas.Tag = 1 then
    TemasAtivos := TemasAtivos + ['Marcas'];
  if recTemasAnimais.Tag = 1 then
    TemasAtivos := TemasAtivos + ['Animais'];
  if recTemasObjetos.Tag = 1 then
    TemasAtivos := TemasAtivos + ['Objetos'];
  if recTemasComida.Tag = 1 then
    TemasAtivos := TemasAtivos + ['Comida'];
  if recTemasPersonagens.Tag = 1 then
    TemasAtivos := TemasAtivos + ['Personagens'];
  if recTemasAtores.Tag = 1 then
    TemasAtivos := TemasAtivos + ['Atores'];
  if recTemasCantores.Tag = 1 then
    TemasAtivos := TemasAtivos + ['Cantores'];

  TemaEscolhido  := TemasAtivos[Random(Length(TemasAtivos))];

  JogadorInicial := Jogadores[Random(Length(Jogadores))].Nome;

  //escolhendo impostores
  for i := 0 to High(Jogadores) do
    Jogadores[i].IsImpostor := False;

  Indices := TList<Integer>.Create;
  try
    for i := 0 to High(Jogadores) do
      Indices.Add(i);

    for i := Indices.Count - 1 downto 1 do
      Indices.Exchange(i, Random(i+1));

    for i := 0 to Trunc(spnImpostor.Value) - 1 do
      Jogadores[Indices[i]].IsImpostor := True;

  finally
    Indices.Free;
  end;

  //filtrando o json de temas
  SetLength(PalavrasFiltradas, 0);
  for i := 0 to High(ListaPalavras) do
    if ListaPalavras[i].Categoria.ToUpper = TemaEscolhido.ToUpper then
    begin
      SetLength(PalavrasFiltradas, Length(PalavrasFiltradas) + 1);
      PalavrasFiltradas[High(PalavrasFiltradas)] := ListaPalavras[i];
    end;

  if Length(PalavrasFiltradas) > 0 then
    PalavraEscolhida := PalavrasFiltradas[Random(Length(PalavrasFiltradas))];

  for i := 0 to High(Jogadores) do
  begin
    if (Jogadores[i].IsImpostor) then
    begin
      if (recDicas.Tag = 1) then
        Jogadores[i].Palavra := PalavraEscolhida.Dica;
    end
    else
      Jogadores[i].Palavra := PalavraEscolhida.Palavra;
  end;

end;

procedure TfrmImpostor.CarregarPalavrasDoJSON(const JSONStr: string);
var
  JSONArray: TJSONArray;
  JSONObject: TJSONObject;
  i: Integer;
  PalavraRec: TPalavra;
begin
  JSONArray := TJSONObject.ParseJSONValue(JSONStr) as TJSONArray;
  if JSONArray = nil then
    Exit;

  try
    SetLength(ListaPalavras, JSONArray.Count);
    for i := 0 to JSONArray.Count - 1 do
    begin
      JSONObject := JSONArray.Items[i] as TJSONObject;

      PalavraRec.Categoria := JSONObject.GetValue('categoria').Value;
      PalavraRec.Palavra   := JSONObject.GetValue('palavra').Value;
      PalavraRec.Dica      := JSONObject.GetValue('dica').Value;

      ListaPalavras[i] := PalavraRec;
    end;
  finally
    JSONArray.Free;
  end;
end;

procedure TfrmImpostor.spnJogadoresChange(Sender: TObject);
begin
  spnImpostor.Max := Trunc(spnJogadores.Text.ToInteger / 3);
end;

procedure TfrmImpostor.tabChange(Sender: TObject);
begin
  lbBotao.Text := 'Começar';
  lytBotao.Visible := True;
  Balao.Visible := False;
  AniBalao.Stop;

  if tab.ActiveTab = tbNomes then
  begin
    ColocarNomes;
  end
  else if tab.ActiveTab = tbJogo then
  begin
    lbBotao.Text := 'Voltar';
    TestaSeTodosJaViram;
  end
  else if tab.ActiveTab = tbRegras then
  begin
    Layout6.Visible := recVerTema.Tag = 1;
    lbBotao.Text := 'Jogar de novo';
    if recPontos.Tag = 1 then
      lbBotao.Text := 'Pontos';
    MontaTelaRegras;
  end
  else if tab.ActiveTab = tbVerCondicao then
  begin
    lbBotao.Text := 'Voltar';
    recFrontPlayer.Visible := True;
    recBackPlayer.Visible  := False;
    recFrontPlayer.Opacity := 1;
    recBackPlayer.Opacity  := 0;
  end
  else if tab.ActiveTab = tbMain then
  begin
    Balao.Visible := True;
    AniBalao.Start;
  end
  else if tab.ActiveTab = tbPontos then
  begin
    lbBotao.Text := 'Jogar de novo';
    MontaTelaPontos;
  end
  else if tab.ActiveTab = tbVencedor then
  begin
    lbBotao.Text := 'Jogar de novo';
  end;
end;

procedure TfrmImpostor.MontaTelaPontos;
var
  i     : integer;
  Layout: TLayout;
  Nome  : TLabel;
  Spin  : TSpinBox;
  Sombra: TShadowEffect;
begin
  Label11.Text := sMsgPontos;
  Label11.Text := StringReplace(Label11.Text, '||', spnQtePontos.Value.ToString, [rfReplaceAll]);

  if Assigned(LayoutPontos) then
  begin
    for Layout in LayoutPontos do
      Layout.DisposeOf;
    LayoutPontos.Clear;
  end
  else
    LayoutPontos := TList<TLayout>.Create;

  for i := 0 to High(Jogadores) do
  begin
    Layout := TLayout.Create(Self);
    Layout.Parent := vertPontos;
    Layout.Height := 45;
    Layout.Align:= TAlignLayout.Top;
    LayoutPontos.Add(Layout);

    Nome := TLabel.Create(Layout);
    Nome.Parent:= Layout;
    Nome.Text := Jogadores[i].Nome;
    Nome.Align:= TAlignLayout.Client;
    Nome.TextSettings.Font.Size := 20;
    Nome.TextSettings.Font.Style := [TFontStyle.fsBold];
    Nome.TextSettings.FontColor := TAlphaColors.White;
    Nome.TextSettings.HorzAlign := TTextAlign.Leading;
    Nome.TextSettings.VertAlign := TTextAlign.Center;
    Nome.StyledSettings := [];
    Nome.HitTest := False;

    Sombra := TShadowEffect.Create(Layout);
    Sombra.Parent := Layout;
    Sombra.Opacity := 0.3;
    Sombra.Distance := 6;
    Sombra.Direction := 90;
    Sombra.Softness := 0.4;

    Spin := TSpinBox.Create(Layout);
    Spin.Parent := Layout;
    Spin.Align := TAlignLayout.Right;
    Spin.Value := Jogadores[i].Pontos;
    Spin.TextSettings.Font.Size := 20;
    Spin.TextSettings.Font.Style := [TFontStyle.fsBold];
    Spin.TextSettings.FontColor := TAlphaColors.White;
    Spin.StyledSettings := [];
    Spin.Width := 120;
    Spin.Tag := Jogadores[i].ID;
    Spin.OnChange := CalculaPontos;
  end;
end;

procedure TFrmImpostor.CalculaPontos(Sender: TObject);
begin
  var Spin := Sender as TSpinBox;
  Jogadores[Spin.Tag - 1].Pontos := Trunc(Spin.Value);
  ChecaGanhador;
end;

procedure TFrmImpostor.ChecaGanhador;
begin
  for var jogador in jogadores do
    if jogador.Pontos >= spnQtePontos.Value then
    begin
      vertPontos.Enabled := False;
      AnimaCircle;
    end;
end;

procedure TfrmImpostor.MontaTelaRegras;
var
  i:integer;
  Impostores: TStringList;
  qteImpostores: integer;
begin
  Impostores := TStringList.Create;
  try
    recFrontResposta.Visible := True;
    recBackResposta.Visible  := False;
    recFrontResposta.Opacity := 1;
    recBackResposta.Opacity  := 0;
    lblRegrasTema.Text := TemaEscolhido;
    lblRegrasPlayerInicial.Text := JogadorInicial;

    for i := 0 to High(Jogadores) do
      if Jogadores[i].IsImpostor then
        Impostores.Add(Jogadores[i].Nome);


    lblRegrasImpostorFront.Text := 'Toque duas vezes para descobrir o impostor !!!';
    if Trunc(spnImpostor.Value) > 1 then
      lblRegrasImpostorFront.Text := 'Toque duas vezes para descobrir os impostores !!!';

    lblRegrasImpostorBack.TextSettings.Font.Size := 35;
    if Impostores.Count > 4 then
      lblRegrasImpostorBack.TextSettings.Font.Size := 22;
    lblRegrasImpostorBack.Text := Impostores.Text;

  finally
    Impostores.Free;
  end;
end;


