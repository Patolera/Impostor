procedure TfrmImpostor.Switch(rect:TRectangle;  circle:TCircle);
begin
  if rect.Tag = 0 then
  begin
    circle.AnimateFloat('Position.X', rect.Width - circle.Width - circle.Margins.Right, 0.2);
    rect.Tag := 1;
    rect.Fill.Color := TAlphaColors.Cornflowerblue;

  end
  else
  begin
    circle.AnimateFloat('Position.X', circle.Margins.Left, 0.2);
    rect.Tag := 0;
    rect.Fill.Color := TAlphaColors.Darkgray;
  end
end;

procedure TfrmImpostor.ColocarNomes;
var
  i   : integer;
  Edit: TEdit;
begin
  SetLength(Jogadores, Trunc(spnJogadores.Value));

  if Assigned(Edits) then
  begin
    for Edit in Edits do
      Edit.DisposeOf;
    Edits.Clear;
  end
  else
    Edits := TList<TEdit>.Create;

  for i := 0 to High(Jogadores) do
  begin
    Edit := TEdit.Create(Self);
    Edit.Parent := vertNomes;
    Edit.Position.X := 10;
    Edit.Position.Y := i * 55;
    Edit.Width := vertNomes.Width - 20;
    Edit.Height := 45;
    Edit.MaxLength := 8;
    Edit.StyledSettings := [];
    Edit.TextSettings.Font.Size := 30;
    Edit.TextSettings.Font.Style := [TFontStyle.fsBold];
    Edit.TextSettings.FontColor  := TAlphaColors.White;
    Edit.CharCase:= TEditCharCase.ecUpperCase;
    Edit.TextPrompt := 'Jogador ' + (i+1).ToString;
    Edits.Add(Edit);
  end;
end;

procedure TfrmImpostor.ComecaJogo;
const
  Colunas = 3;
  Espacamento = 12;
var
  Icone, Fundo: TRectangle;
  Nome: TLabel;
  Flow: TRectangle;
  Tamanho: Single;
  Sombra: TShadowEffect;
  i, Linha, Coluna: Integer;
  X, Y: Single;
begin
  vertPlayers.BeginUpdate;
  try
    if Assigned(Flows) then
    begin
      for Flow in Flows do
        Flow.DisposeOf;
      Flows.Clear;
    end
    else
      Flows := TList<TRectangle>.Create;

    Tamanho := (vertPlayers.Width - (Espacamento * (Colunas + 1))) / Colunas;
    for i := 0 to High(Jogadores) do
    begin
      Linha := i div Colunas;
      Coluna := i mod Colunas;

      X := Espacamento + Coluna * (Tamanho + Espacamento);
      Y := Espacamento + Linha * (Tamanho + Espacamento);

      Fundo := TRectangle.Create(vertPlayers);
      Fundo.Parent := vertPlayers;
      Fundo.Width := Tamanho;
      Fundo.Height := Tamanho;
      Fundo.Position.X := X;
      Fundo.Position.Y := Y;
      Fundo.XRadius := 20;
      Fundo.YRadius := 20;
      Fundo.Fill.Color := $FF3B82F6;
      Fundo.Stroke.Kind := TBrushKind.None;
      Fundo.HitTest := True;
      Fundo.Opacity := 1;
      Fundo.Tag := Jogadores[i].ID;
      Fundo.OnClick := PlayerClick;
      Flows.Add(Fundo);

      Sombra := TShadowEffect.Create(Fundo);
      Sombra.Parent := Fundo;
      Sombra.Opacity := 0.3;
      Sombra.Distance := 6;
      Sombra.Direction := 90;
      Sombra.Softness := 0.4;

      Nome := TLabel.Create(Fundo);
      Nome.Parent := Fundo;
      Nome.Align := TAlignLayout.Client;
      Nome.Margins.Bottom := 10;
      Nome.Text := Jogadores[i].Nome;
      Nome.TextSettings.Font.Size := 16;
      Nome.TextSettings.Font.Style := [TFontStyle.fsBold];
      Nome.TextSettings.FontColor := TAlphaColors.White;
      Nome.TextSettings.HorzAlign := TTextAlign.Center;
      Nome.TextSettings.VertAlign := TTextAlign.Center;
      Nome.StyledSettings := [];
      Nome.HitTest := False;

    end;
  finally
    vertPlayers.EndUpdate;
  end;

end;

