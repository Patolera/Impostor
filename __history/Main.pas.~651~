procedure TfrmImpostor.FadeTroca(FrontRect, BackRect: TRectangle);
var
  AnimFade: TFloatAnimation;
begin
  AnimFade := TFloatAnimation.Create(FrontRect);
  AnimFade.Parent := FrontRect;
  AnimFade.PropertyName := 'Opacity';
  AnimFade.StartValue := 1;
  AnimFade.StopValue := 0;
  AnimFade.Duration := 1;
  AnimFade.Interpolation := TInterpolationType.Sinusoidal;

  FrontRect.TagObject := BackRect;
  AnimFade.OnFinish := AnimFadeFinish;
  AnimFade.Start;
end;

